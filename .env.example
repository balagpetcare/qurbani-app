# Copy to `.env` for local development. In production, set these in your host / CI secrets — never commit `.env`.

# --- Required ---
# PostgreSQL connection string (sslmode=require typical on managed Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/qurbani_db?schema=public"

# HMAC key for signed cookie `qurbani_auth`. Required in production (see src/lib/auth-token.ts).
# Generate e.g. openssl rand -base64 32
SESSION_SECRET=

# --- Seed (required to run `npm run db:seed`) ---
# bcrypt hash is stored on the Main Admin user — change password after first login if needed.
ADMIN_SEED_PASSWORD=

# Optional overrides (defaults exist in prisma/seed.ts if unset)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PHONE=

# --- Public site URL (optional; enables Open Graph URLs + canonical metadata for PWA/sharing) ---
# NEXT_PUBLIC_APP_URL=https://your-domain.example

# --- Optional emergency admin login (only if seeded admin has no passwordHash yet) ---
# Prefer seeding with ADMIN_SEED_PASSWORD instead.
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# --- Public POST rate limits (in-memory per Node instance; use Redis/Upstash in multi-instance prod) ---
# PUBLIC_RATE_LIMIT_DISABLED=1
# PUBLIC_LEAD_RATE_IP_LIMIT=24
# PUBLIC_LEAD_RATE_IP_WINDOW_MS=900000
# PUBLIC_LEAD_RATE_PHONE_LIMIT=8
# PUBLIC_LEAD_RATE_PHONE_WINDOW_MS=3600000
# PUBLIC_APP_RATE_IP_LIMIT=12
# PUBLIC_APP_RATE_IP_WINDOW_MS=3600000
# PUBLIC_APP_RATE_PHONE_LIMIT=4
# PUBLIC_APP_RATE_PHONE_WINDOW_MS=86400000

# --- Mobile lead media (Vercel Blob; optional) ---
# Create a Blob store in Vercel → copy read/write token. Without it, POST /api/mobile/media/upload-url returns available:false (Flutter shows Bengali notice; no fake uploads).
# BLOB_READ_WRITE_TOKEN=

# Optional: rate limit anonymous media upload-url + ingest (per IP, in-memory; see src/lib/public-rate-limit.ts)
# PUBLIC_MEDIA_UPLOAD_RATE_IP_LIMIT=40
# PUBLIC_MEDIA_UPLOAD_RATE_IP_WINDOW_MS=3600000

# Optional: rate limit mobile customer OTP (per IP + per phone; in-memory; see src/lib/public-rate-limit.ts)
# PUBLIC_OTP_START_RATE_IP_LIMIT=40
# PUBLIC_OTP_START_RATE_IP_WINDOW_MS=3600000
# PUBLIC_OTP_START_RATE_PHONE_LIMIT=6
# PUBLIC_OTP_START_RATE_PHONE_WINDOW_MS=3600000
# PUBLIC_OTP_VERIFY_RATE_IP_LIMIT=80
# PUBLIC_OTP_VERIFY_RATE_IP_WINDOW_MS=3600000
# PUBLIC_OTP_VERIFY_RATE_PHONE_LIMIT=20
# PUBLIC_OTP_VERIFY_RATE_PHONE_WINDOW_MS=3600000

# Optional: rate limit POST /api/mobile/device-token (per IP, in-memory)
# PUBLIC_DEVICE_TOKEN_RATE_IP_LIMIT=120
# PUBLIC_DEVICE_TOKEN_RATE_IP_WINDOW_MS=3600000

# --- Future: server-side FCM (Admin SDK). Do not set until ready to send production pushes. ---
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# Or use host-specific secret injection; no keys in repo.

# --- BulkSMSBD (server-only; never expose keys to Flutter or browser JS) ---
# SMS_PROVIDER=bulksmsbd
# SMS_ENABLED=true
# SMS_DRY_RUN=false
# Primary credentials (aliases supported — same BulkSMSBD-compatible POST):
# SMS_API_URL=http://bulksmsbd.net/api/smsapi
# SMS_API_KEY=
# SMS_SENDER_ID=
# Or legacy names:
# BULKSMSBD_API_KEY=
# BULKSMSBD_SENDER_ID=
# BULKSMSBD_BASE_URL=http://bulksmsbd.net/api
# SMS_BRAND_NAME=Quarbani 2026
# PUBLIC_APP_URL=https://your-domain.example
#
# --- Public lead form SMS (POST /api/leads) ---
# OFFICIAL_LEAD_RECEIVE_PHONE=01XXXXXXXXX
# CUSTOMER_SUPPORT_PHONE=01XXXXXXXXX
# Legacy fallback for office alerts if OFFICIAL_LEAD_RECEIVE_PHONE is unset:
# ADMIN_SMS_ALERT_PHONE=

# --- Mobile customer OTP SMS (legacy flag; prefer SMS_ENABLED=true) ---
# Without SMS_ENABLED=true and BulkSMSBD credentials, OTP is not sent over SMS (dev: optional MOBILE_OTP_DEV_REVEAL).
# SMS_OTP_ENABLED=1
# Non-production only: return plaintext OTP in JSON for local E2E (never enable in production).
# MOBILE_OTP_DEV_REVEAL=1

# --- Mobile customer social login (optional; see docs/SOCIAL_LOGIN_IMPLEMENTATION_REPORT.md) ---
# Google id_token audiences (comma-separated web/Android/iOS client IDs). Must include the ID used as GOOGLE_SIGN_IN_SERVER_CLIENT_ID in Flutter.
# GOOGLE_OAUTH_CLIENT_IDS=xxxxx.apps.googleusercontent.com
# Or single audience:
# GOOGLE_WEB_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Facebook: public app id + server-only secret (never in Flutter).
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# Apple Sign In: bundle id and/or Services ID — comma-separated if both tokens must verify (matches identityToken `aud`).
# APPLE_CLIENT_ID=com.example.app,com.example.app.service
# Optional rate limits for POST /api/mobile/auth/social (see src/lib/public-rate-limit.ts)
# MOBILE_SOCIAL_AUTH_RATE_IP_LIMIT=40
# MOBILE_SOCIAL_AUTH_RATE_IP_WINDOW_MS=3600000

# --- Future outbound notification drivers (no secrets here; set tokens in host secrets) ---
# QURBANI_NOTIFICATION_WHATSAPP_DRIVER=none
# QURBANI_NOTIFICATION_SMS_DRIVER=none
# QURBANI_NOTIFICATION_EMAIL_DRIVER=none
