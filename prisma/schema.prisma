// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DOCTOR
  STAFF
  /// Mobile app customer (OTP); never used for admin/doctor portal login.
  CUSTOMER
}

/// Third-party identity linked to a mobile customer [User] row.
enum SocialAuthProvider {
  GOOGLE
  FACEBOOK
  APPLE
}

/// FCM/APNs device registration (mobile app only).
enum PushDevicePlatform {
  ANDROID
  IOS
}

enum LeadStatus {
  NEW
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  OBSERVED
  COMPLETED
  FOLLOW_UP_NEEDED
  CANCELLED
  REFERRED
}

enum DoctorApplicationStatus {
  NEW
  REVIEWED
  APPROVED
  REJECTED
  CONVERTED_TO_DOCTOR
}

enum NotificationChannel {
  IN_APP
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationType {
  NEW_LEAD
  DOCTOR_ASSIGNED
  STATUS_CHANGED
  FOLLOW_UP
  DOCTOR_APPLICATION
  EMERGENCY_LEAD
  CASE_ACCEPTED_BY_DOCTOR
  DOCTOR_APPLICATION_REVIEWED
}

enum LeadPriority {
  NORMAL
  URGENT
  EMERGENCY
}

enum AnimalKind {
  CATTLE
  GOAT
  SHEEP
  BUFFALO
  OTHER
}

enum LeadContactPreference {
  CALL
  WHATSAPP
  VISIT
}

enum DoctorAreaPreferenceStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Geographic grouping for Dhaka / peri-urban service areas (admin + analytics).
enum ServiceAreaZone {
  NORTH_DHAKA
  CENTRAL_DHAKA
  OLD_DHAKA
  SOUTH_DHAKA
  WEST_DHAKA
  OUTSIDE_DHAKA
}

/// How the customer paid (or owes); affects settlement rules.
enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  BANK
  ONLINE
  MIXED
  DUE
}

/// Admin reconciliation of platform commission / payouts for a completed case bill.
enum SettlementStatus {
  UNSETTLED
  PENDING_REVIEW
  APPROVED
  PAID_TO_PLATFORM
  PAID_TO_DOCTOR
  DISPUTED
  CANCELLED
}

/// Doctor-authored tutorial lifecycle (admin gate before public).
enum TutorialStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

/// Anonymized public case showcase; admin-gated like tutorials.
enum PublicCaseHistoryStatus {
  DRAFT
  PENDING_APPROVAL
  PUBLISHED
  REJECTED
}

/// What is being reported to moderation.
enum ModerationTargetType {
  TUTORIAL
  TUTORIAL_COMMENT
  PUBLIC_CASE_HISTORY
}

enum ContentReportReason {
  SPAM
  HARASSMENT
  MISINFORMATION
  COPYRIGHT
  OTHER
}

enum ContentReportStatus {
  OPEN
  REVIEWING
  RESOLVED_DISMISSED
  RESOLVED_ACTION_TAKEN
}

/// Snapshot of treatment closure semantics on the billing row (invoice/admin use).
enum TreatmentCompletionStatus {
  COMPLETED
  FOLLOW_UP_NEEDED
  REFERRED
  CANCELLED
}

/// Global configurable site settings (admin-managed).
model SiteSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  /// JSON primitive or object — use helpers in `src/lib/site-settings.ts`.
  value       Json
  group       String
  label       String
  description String?
  /// When true, key may be exposed via safe server-only public loaders (whitelist still applies).
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

/// Doctor asks admin to change assigned areas; admin applies via existing doctor area APIs.
model DoctorAreaPreferenceRequest {
  id               Int                         @id @default(autoincrement())
  userId           Int
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedAreaIds Json
  status           DoctorAreaPreferenceStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@index([userId, status])
}

/// Service areas (seeded; avoid hardcoding only in frontend).
model Area {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  /// Short English / romanized label (search, exports).
  name      String
  /// Primary display name (Bengali).
  nameBn    String?
  /// Optional English display name.
  nameEn    String?
  zone      ServiceAreaZone?
  isPopular Boolean  @default(false)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors       DoctorArea[]
  leads         Lead[]
  applications  DoctorApplicationArea[]

  @@index([zone])
  @@index([isActive, isPopular, sortOrder])
}

/// Doctors (User role DOCTOR) can cover multiple areas.
model DoctorArea {
  userId Int
  areaId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  area   Area @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([userId, areaId])
}

model User {
  id                 Int       @id @default(autoincrement())
  name               String
  phone              String?   @unique
  email              String?   @unique
  passwordHash       String?
  role               UserRole  @default(STAFF)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  whatsapp           String?
  /// @deprecated Prefer DoctorArea; kept for legacy display during transition.
  areaCoverage       String?
  emergencyAvailable Boolean   @default(false)
  notes              String?
  /// Public landing experience line; falls back if `experienceSummary` empty.
  experienceSummary  String?   @db.Text
  qualification      String?
  shortBio           String?   @db.Text
  availableTimeText  String?   @db.Text
  /// Short code: AVAILABLE | LIMITED | OFF
  availabilityStatus String?
  profilePhotoUrl    String?
  /// Public home-visit fee range (BDT, whole taka). Shown on landing; never exposes contact fields.
  homeVisitFeeMin    Int?
  homeVisitFeeMax    Int?
  feeNote            String?   @db.Text
  notifyEmail        Boolean   @default(false)
  notifySms          Boolean   @default(false)
  notifyWhatsApp     Boolean   @default(false)
  assignedLeads      Lead[]    @relation("AssignedDoctor")

  doctorAreas                   DoctorArea[]
  doctorAreaPreferenceRequests  DoctorAreaPreferenceRequest[]
  leadObservations              LeadObservation[]      @relation("LeadObservationDoctor")
  leadCaseReportsCompleted      LeadCaseReport[]       @relation("LeadCaseReportDoctor")
  leadCaseBillingsCompleted     LeadCaseBilling[]      @relation("LeadCaseBillingDoctor")
  leadAssignmentsAsDoctor       LeadAssignment[]       @relation("LeadAssignmentDoctor")
  reviewedDoctorApplications    DoctorApplication[]    @relation("DoctorApplicationReviewer")
  createdFromDoctorApplication  DoctorApplication?     @relation("DoctorApplicationConvertedUser")
  leadStatusHistoryAsActor      LeadStatusHistory[]
  pushDeviceTokens              PushDeviceToken[]
  tutorialsAuthored             Tutorial[]             @relation("TutorialAuthor")
  tutorialsModerated          Tutorial[]             @relation("TutorialReviewedBy")
  tutorialRevisionsCreated      TutorialRevision[]   @relation("TutorialRevisionAuthor")
  contentReportsFiled           ContentReport[]        @relation("ContentReportReporter")
  userBlocksCreated             UserBlock[]            @relation("UserBlocker")
  userBlocksReceived            UserBlock[]            @relation("UserBlocked")
  publicCaseHistoriesAuthored   PublicCaseHistory[]   @relation("PublicCaseHistoryAuthor")
  publicCaseHistoriesModerated  PublicCaseHistory[]   @relation("PublicCaseHistoryReviewedBy")
  /// When set, customer has completed OTP verification for [phone] (or legacy backfill).
  phoneVerifiedAt             DateTime?
  customerSocialLinks         CustomerSocialLink[]
}

/// Links a CUSTOMER user to a stable subject from Google / Facebook / Apple (no refresh tokens stored here).
model CustomerSocialLink {
  id              String             @id @default(cuid())
  userId          Int
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        SocialAuthProvider
  /// IdP-stable subject (Google "sub", Facebook app-scoped user id, Apple "sub").
  providerSubject String             @db.VarChar(255)
  createdAt       DateTime           @default(now())

  @@unique([provider, providerSubject])
  @@unique([userId, provider])
  @@index([userId])
}

/// One row per FCM registration token; [token] is globally unique (reassigned on login change).
model PushDeviceToken {
  id        String              @id @default(cuid())
  userId    Int
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  PushDevicePlatform
  /// FCM registration token (never log in full in production).
  token     String              @unique @db.Text
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId])
}

model DoctorApplication {
  id               Int                     @id @default(autoincrement())
  name             String
  phone            String
  whatsapp         String?
  email            String?
  address          String?
  experience       String?
  qualification    String?
  note             String?
  animalExpertise      String?  @db.Text
  availableTimeText    String?  @db.Text
  emergencyAvailable   Boolean  @default(false)
  ownTransport         Boolean  @default(false)
  /// Optional expected visit fee in BDT (whole taka).
  expectedVisitCharge  Int?
  shortBio             String?  @db.Text
  /// URL to certificate/document until file upload exists.
  certificateUrl       String?
  /// Internal admin observation (not shown to applicant).
  adminReviewNote      String?  @db.Text
  status           DoctorApplicationStatus @default(NEW)
  reviewedAt       DateTime?
  reviewedByUserId Int?
  reviewedBy       User?                   @relation("DoctorApplicationReviewer", fields: [reviewedByUserId], references: [id])
  convertedUserId  Int?                    @unique
  convertedUser    User?                   @relation("DoctorApplicationConvertedUser", fields: [convertedUserId], references: [id])
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  areas DoctorApplicationArea[]
}

model DoctorApplicationArea {
  applicationId Int
  areaId        Int
  application   DoctorApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  area          Area              @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@id([applicationId, areaId])
}

model Lead {
  id                  Int         @id @default(autoincrement())
  customerName        String
  phone               String
  whatsapp            String?
  /// Free-text area label (legacy, custom “অন্যান্য”, or denormalized snapshot).
  area                String?
  /// When null, customer chose “অন্যান্য” and `area` holds the custom label.
  areaId              Int?
  selectedArea        Area?       @relation(fields: [areaId], references: [id])
  address             String?
  /// Legacy free-text animal label; when `animalKind` is OTHER, use for detail.
  animalType          String?
  animalKind          AnimalKind?
  animalCount         Int?
  approxAgeText       String?
  approxWeightKg      Int?
  problemCategory     String?
  problemDuration     String?
  eatingStatus        String?
  feverSuspected      Boolean?
  bellyBloated        Boolean?
  canWalk             Boolean?
  problemDetails      String?
  priority            LeadPriority            @default(NORMAL)
  preferredContact    LeadContactPreference?
  googleMapUrl        String?
  /// JSON array of media URLs (photo/video). File upload TBD — see Q26-CMD-05+.
  mediaUrls           String?                 @db.Text
  preferredDate       DateTime?
  preferredTime       String?
  serviceRequirement  String
  message             String?
  status              LeadStatus  @default(NEW)
  assignedDoctorId    Int?
  assignedDoctor      User?       @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  source              String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmContent          String?
  utmTerm             String?
  utmArea             String?
  landingPath         String?
  isPossibleDuplicate Boolean     @default(false)
  duplicateOfLeadId   Int?
  duplicateOf         Lead?       @relation("LeadDuplicateOf", fields: [duplicateOfLeadId], references: [id], onDelete: SetNull)
  duplicateCopies     Lead[]      @relation("LeadDuplicateOf")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  notes               LeadNote[]
  notifications       Notification[]
  observations        LeadObservation[]
  assignments         LeadAssignment[]
  caseReport          LeadCaseReport?
  caseBilling         LeadCaseBilling?
  statusHistory       LeadStatusHistory[]
  publicCaseHistory   PublicCaseHistory?

  @@index([priority])
  @@index([phone, createdAt])
}

/// One-time password challenge for mobile customer login. Plain OTP is never stored.
model CustomerOtpChallenge {
  id           String    @id @default(cuid())
  /// Canonical Bangladesh mobile `01[3-9]XXXXXXXX` (matches [Lead.phone] after intake).
  phoneCanon   String
  codeHash     String
  expiresAt    DateTime
  attemptCount Int       @default(0)
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([phoneCanon, createdAt])
}

/// Doctor-entered treatment record; draft until completedAt is set.
model LeadCaseReport {
  id                     Int       @id @default(autoincrement())
  leadId                 Int       @unique
  lead                   Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  /// Clinical observation / examination notes (draft-friendly).
  observation            String?   @db.Text
  doctorAdvice           String?   @db.Text
  diagnosis              String?   @db.Text
  treatmentGiven         String?   @db.Text
  medicineAdvice         String?   @db.Text
  followUpNeeded         Boolean   @default(false)
  nextFollowUpAt         DateTime?
  publicShowcaseEligible Boolean   @default(false)
  /// Public-facing title — must not include customer PII (enforced in UI copy only).
  showcaseTitle          String?
  showcaseSummary        String?   @db.Text
  completedAt            DateTime?
  completedByDoctorId    Int?
  completedBy            User?     @relation("LeadCaseReportDoctor", fields: [completedByDoctorId], references: [id])
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  publicCaseHistoryAsSource PublicCaseHistory? @relation("PublicCaseHistorySourceCaseReport")
}

/// Snapshot when a case is closed with billing: amounts, commission, settlement, invoice id.
/// Clinical narrative may also exist on `LeadCaseReport`; this row is the financial + invoice source of truth.
model LeadCaseBilling {
  id        Int      @id @default(autoincrement())
  leadId    Int      @unique
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  doctorId  Int
  doctor    User     @relation("LeadCaseBillingDoctor", fields: [doctorId], references: [id])

  completedAt DateTime
  status      TreatmentCompletionStatus @default(COMPLETED)

  observation   String? @db.Text
  diagnosis     String? @db.Text
  treatmentNote String? @db.Text
  /// Free-text list of medicines (structured lines optional below).
  medicinesUsed String? @db.Text
  /// Optional structured lines, e.g. [{ "name": "...", "qty": 1, "amount": 100 }].
  medicineLines Json?

  serviceFee      Int @default(0)
  medicineCharge  Int @default(0)
  transportCharge Int @default(0)
  emergencyCharge Int @default(0)
  otherCharge     Int @default(0)
  discountAmount  Int @default(0)

  /// service + medicine + transport + emergency + other - discount (whole BDT).
  grossAmount Int @default(0)
  totalCollected Int @default(0)
  dueAmount      Int @default(0)

  paymentMethod PaymentMethod

  commissionableAmount       Int   @default(0)
  /// Percent snapshot at billing time, e.g. 10.0 means 10%.
  platformCommissionRate     Float @default(0)
  platformCommissionAmount     Int   @default(0)
  doctorEarningAmount          Int   @default(0)
  doctorPayableToPlatform      Int   @default(0)
  settlementStatus             SettlementStatus @default(UNSETTLED)

  followUpRequired Boolean   @default(false)
  followUpAt       DateTime?

  /// Human-readable unique invoice reference (assigned when billing is created).
  invoiceNo String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([doctorId])
  @@index([doctorId, completedAt])
  @@index([settlementStatus])
}

model LeadStatusHistory {
  id          Int         @id @default(autoincrement())
  leadId      Int
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  fromStatus  LeadStatus?
  toStatus    LeadStatus
  actorKind   String
  actorUserId Int?
  actor       User?       @relation(fields: [actorUserId], references: [id])
  note        String?
  createdAt   DateTime    @default(now())

  @@index([leadId])
}

model LeadObservation {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  doctorId  Int
  doctor    User     @relation("LeadObservationDoctor", fields: [doctorId], references: [id])
  condition String?
  note      String?
  visitedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([doctorId])
}

model LeadAssignment {
  id               Int       @id @default(autoincrement())
  leadId           Int
  lead             Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  doctorId         Int
  doctor           User      @relation("LeadAssignmentDoctor", fields: [doctorId], references: [id])
  assignedAt       DateTime  @default(now())
  unassignedAt     DateTime?
  assignedByUserId Int?

  @@index([leadId])
}

model Notification {
  id              Int                  @id @default(autoincrement())
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus   @default(PENDING)
  leadId          Int?
  lead            Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  recipientName   String?
  recipientPhone  String?
  message         String
  errorMessage    String?
  createdAt       DateTime             @default(now())
  sentAt          DateTime?
}

model LeadNote {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  note      String
  createdBy String?
  createdAt DateTime @default(now())
}

/// Canonical tutorial row; public APIs only when status is PUBLISHED.
model Tutorial {
  id                  Int            @id @default(autoincrement())
  authorUserId        Int
  author              User           @relation("TutorialAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  status              TutorialStatus @default(DRAFT)
  /// Active content pointer (draft edits or revision pending / published face).
  currentRevisionId   Int?           @unique
  currentRevision     TutorialRevision? @relation("TutorialCurrentRevision", fields: [currentRevisionId], references: [id], onDelete: SetNull)
  submittedAt         DateTime?
  publishedAt         DateTime?
  rejectedAt          DateTime?
  rejectionReason     String?        @db.Text
  reviewedByUserId    Int?
  reviewedBy          User?          @relation("TutorialReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  likeCount           Int            @default(0)
  commentCount        Int            @default(0)
  shareCount          Int            @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  revisions           TutorialRevision[] @relation("TutorialRevisionList")

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorUserId, status])
}

model TutorialRevision {
  id               Int      @id @default(autoincrement())
  tutorialId       Int
  tutorial         Tutorial @relation("TutorialRevisionList", fields: [tutorialId], references: [id], onDelete: Cascade)
  revisionNumber   Int
  titleBn          String
  summaryBn        String?  @db.Text
  bodyBn           String?  @db.Text
  videoUrl         String
  posterImageUrl   String?
  durationSec      Int?
  mimeType         String?
  byteSize         Int?
  createdByUserId  Int?
  createdBy        User?    @relation("TutorialRevisionAuthor", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tutorialAsCurrent Tutorial? @relation("TutorialCurrentRevision")

  @@unique([tutorialId, revisionNumber])
  @@index([tutorialId])
}

model ContentReport {
  id                  Int                   @id @default(autoincrement())
  reporterUserId      Int
  reporter            User                  @relation("ContentReportReporter", fields: [reporterUserId], references: [id], onDelete: Cascade)
  targetType          ModerationTargetType
  targetId            Int
  reason              ContentReportReason
  details             String?               @db.Text
  status              ContentReportStatus   @default(OPEN)
  assignedAdminUserId Int?
  resolutionNote      String?               @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([targetType, targetId])
  @@index([reporterUserId, createdAt])
  @@index([status])
}

model UserBlock {
  id            Int      @id @default(autoincrement())
  blockerUserId Int
  blockedUserId Int
  blocker       User     @relation("UserBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User     @relation("UserBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId])
  @@index([blockedUserId])
}

/// Anonymized case showcase; never stores customer PII. One row per source lead.
model PublicCaseHistory {
  id                   Int                       @id @default(autoincrement())
  sourceLeadId         Int                       @unique
  lead                 Lead                      @relation(fields: [sourceLeadId], references: [id], onDelete: Cascade)
  sourceCaseReportId   Int?                      @unique
  sourceCaseReport     LeadCaseReport?           @relation("PublicCaseHistorySourceCaseReport", fields: [sourceCaseReportId], references: [id], onDelete: SetNull)
  authorDoctorUserId   Int
  authorDoctor         User                      @relation("PublicCaseHistoryAuthor", fields: [authorDoctorUserId], references: [id], onDelete: Cascade)
  status               PublicCaseHistoryStatus   @default(DRAFT)
  titleBn              String
  summaryBn            String?                   @db.Text
  bodyBn               String?                   @db.Text
  animalKind           AnimalKind?
  /// Short label when animalKind is OTHER (doctor-edited; validated for PII patterns).
  animalTypeLabelBn    String?
  problemSummaryBn     String                    @db.Text
  diagnosisSummaryBn   String?                   @db.Text
  treatmentSummaryBn   String?                   @db.Text
  resultSummaryBn      String?                   @db.Text
  /// Coarse public area label (zone/region BN); never full street address.
  areaBucket           String
  /// JSON array of approved https media URLs (MVP: doctor-submitted, admin-approved on publish).
  mediaUrls            String?                   @db.Text
  posterImageUrl       String?
  submittedAt          DateTime?
  publishedAt          DateTime?
  rejectedAt           DateTime?
  rejectionReason      String?                   @db.Text
  reviewedByUserId     Int?
  reviewedBy           User?                     @relation("PublicCaseHistoryReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  likeCount            Int                       @default(0)
  commentCount         Int                       @default(0)
  shareCount           Int                       @default(0)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorDoctorUserId, status])
}
